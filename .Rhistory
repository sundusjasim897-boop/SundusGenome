library(BiocManager)
BiocManager::install("BSgenome.Ecoli.NCBI.20080805")
library(BSgenome.Ecoli.NCBI.20080805)
ecoli = as.character(Ecoli$NC_004431)
motif = "[TA]ACTGTATATA.A.[AC]CAG[TC][AT]"
comp = chartr("ATCG", "TAGC", ecoli)
ecoliRC = paste(rev(strsplit(comp, "")[[1]]), collapse = "")
matches_ecoli = gregexpr(motif, ecoli)[[1]]
matches_ecoliRC = gregexpr(motif, ecoliRC)[[1]]
matches_ecoli
matches_ecoliRC
length(matches_ecoli[matches_ecoli > 0])
length(matches_ecoliRC[matches_ecoliRC > 0])
