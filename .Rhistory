g = new("Genome", genome_name = "Human", num_chromosomes = 23, num_proteins = 20000)
setClass(
"Genome",
slots = list(
genome_name = "character",
num_chromosomes = "numeric",
num_proteins = "numeric"
)
)
setGeneric(
"avgProteinPerCh",
function(object) standardGeneric("avgProteinPerCh")
)
setMethod(
"avgProteinPerCh",
"Genome",
function(object) {
avg = object@num_proteins / object@num_chromosomes
return(round(avg))
}
)
